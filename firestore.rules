rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Admin escape hatch (Only for nako163282@gmail.com as specified in runtime)
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'nako163282@gmail.com' && isEmailVerified(); 
    }

    // 4. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email']) 
        && data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (!('dailyGoal' in data) || data.dailyGoal is number)
        && (!('program' in data) || (data.program is string && data.program.size() <= 200))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000))
        && data.userId == request.auth.uid;
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['name', 'color'])
        && data.name is string && data.name.size() <= 100
        && data.color is string && data.color.size() <= 20
        && (!('progress' in data) || (data.progress is number && data.progress >= 0 && data.progress <= 100));
    }

    function isValidTopic(data) {
      return data.keys().hasAll(['title', 'status'])
        && data.title is string && data.title.size() <= 200
        && data.status in ['completed', 'in_progress', 'not_started'];
    }

    function isValidDeadline(data) {
      return data.keys().hasAll(['title', 'date', 'type'])
        && data.title is string && data.title.size() <= 200
        && data.date is string // Or timestamp if using serverValue
        && data.type in ['exam', 'assignment', 'lab', 'quiz', 'other'];
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['score', 'total', 'topic'])
        && data.score is number && data.total is number
        && data.topic is string && data.topic.size() <= 200;
    }

    function isValidReviewItem(data) {
      return data.keys().hasAll(['title', 'nextReview'])
        && data.title is string && data.title.size() <= 200
        && data.nextReview is string;
    }

    // 2. Collection Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
                    && isValidUser(incoming())
                    && incoming().userId == existing().userId; // Immutable UID

      match /subjects/{subjectId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(subjectId) && isValidSubject(incoming());
        allow update: if (isOwner(userId) || isAdmin()) && isValidSubject(incoming());
        allow delete: if isOwner(userId) || isAdmin();

        match /topics/{topicId} {
          allow list: if isOwner(userId) || isAdmin();
          allow get: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) || isAdmin()) && isValidId(topicId) && isValidTopic(incoming());
          allow update: if (isOwner(userId) || isAdmin()) && isValidTopic(incoming());
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /deadlines/{deadlineId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(deadlineId) && isValidDeadline(incoming());
        allow update: if (isOwner(userId) || isAdmin()) && isValidDeadline(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /quiz_results/{resultId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(resultId) && isValidQuizResult(incoming());
        // No updates for historical results
      }

      match /review_queue/{itemId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(itemId) && isValidReviewItem(incoming());
        allow update: if (isOwner(userId) || isAdmin()) && isValidReviewItem(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
